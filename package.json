{
  "name": "qua-engine",
  "version": "1.0.0",
  "description": "A new web-based Adventure Game Engine with plugin support",
  "main": "dist/qua-engine.umd.js",
  "module": "dist/qua-engine.esm.js",
  "typings": "dist/types/index.d.ts",
  "keywords": [
    "galgame",
    "game",
    "engine",
    "game engine",
    "typescript",
    "lib"
  ],
  "scripts": {
    "watch": "rollup -c rollup.config.ts -w",
    "build": "rimraf ./dist && tsc --module commonjs && rollup -c rollup.config.ts && rimraf ./dist/lib"
  },
  "author": "QuaDevTeam",
  "license": "Apache 2.0",
  "devDependencies": {
    "@rollup/plugin-commonjs": "^21.0.1",
    "@rollup/plugin-json": "^4.1.0",
    "@rollup/plugin-node-resolve": "^13.1.3",
    "@types/node": "^17.0.8",
    "@typescript-eslint/eslint-plugin": "^5.9.0",
    "@typescript-eslint/parser": "^5.9.0",
    "eslint": "^8.6.0",
    "eslint-config-alloy": "^4.4.0",
    "eslint-config-prettier": "^8.3.0",
    "prettier": "^2.5.1",
    "rimraf": "^3.0.2",
    "rollup": "^2.63.0",
    "rollup-plugin-sourcemaps": "^0.6.3",
    "rollup-plugin-typescript2": "^0.31.1",
    "tslib": "^2.3.1",
    "typescript": "^4.5.4"
  },
  "dependencies": {
    "mitt": "^3.0.0",
    "quastore": "^0.0.4"
  }
}
